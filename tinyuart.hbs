namespace eval vhdl::tinyuart {
  set doc "A very tiny UART transmitter and receiver with the fixed 8N1 configuration:
  - 8 - eight data bits
  - N - no parity bit,
  - 1 - one stop bit."

  proc src {} {
    hbs::SetLib "ltinyuart"
    hbs::AddFile tinyuart.vhd
  }

  proc _tb {top} {
    hbs::SetTool "nvc"
    hbs::AddPostElabCb hbs::SetArgPrefix "--messages=compact"
    hbs::SetTop $top
    src
    hbs::SetLib ""
    hbs::AddFile [string map {_ -} $top].vhd ;# Replace '_' with '-' in file name.
  }

  # Transmitter testbench
  proc tb-tx {} {
    _tb "tb_tx"
    hbs::Run
  }

  # Receiver testbench
  proc tb-rx {} {
    _tb "tb_rx"
    hbs::Run
  }

  # Loopback testbench
  proc tb-loopback {} {
    _tb "tb_loopback"
    hbs::Run
  }

  hbs::Register $doc
}